{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/roykollensvendsen/hypotheses/src/hypotheses/spec/schema/hypothesis.schema.json",
  "title": "Hypothesis spec",
  "description": "YAML front matter for files under hypotheses/. See docs/spec/02-hypothesis-format.md.",

  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "authors",
    "status",
    "version",
    "created",
    "updated",
    "claim",
    "motivation",
    "variables",
    "metrics",
    "baselines",
    "protocol",
    "success_criteria",
    "falsification_criteria",
    "oracle",
    "depends_on",
    "contradicts"
  ],

  "properties": {
    "id": {
      "type": "string",
      "pattern": "^H-(\\d{4}|XXXX)$",
      "description": "H-NNNN where NNNN is four decimal digits; H-XXXX is reserved for the template."
    },
    "title": { "type": "string", "minLength": 1 },

    "authors": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/author" }
    },

    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "accepted",
        "running",
        "settled-supported",
        "settled-refuted",
        "withdrawn"
      ]
    },

    "version": { "type": "integer", "minimum": 1 },

    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },

    "claim": { "type": "string", "minLength": 1 },
    "motivation": { "type": "string", "minLength": 1 },

    "variables": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/variable" }
    },

    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/metric" }
    },

    "baselines": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/baseline" }
    },

    "protocol": { "$ref": "#/$defs/protocol" },

    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/criterion" }
    },

    "falsification_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/criterion" }
    },

    "oracle": { "$ref": "#/$defs/oracle" },

    "depends_on": {
      "type": "array",
      "items": { "type": "string", "pattern": "^H-\\d{4}$" }
    },
    "contradicts": {
      "type": "array",
      "items": { "type": "string", "pattern": "^H-\\d{4}$" }
    },

    "analysis_plan": {
      "$ref": "#/$defs/analysis_plan",
      "description": "Optional pre-analysis plan. HM-REQ-0050 makes this effectively required for Phase 1+ scoring; the schema keeps it optional so Phase 0 fixtures grandfather. Generic preregistration without analysis-plan detail does not reduce p-hacking (JPE 2024)."
    },
    "external_anchor": {
      "$ref": "#/$defs/external_anchor",
      "description": "Optional explicit external-verifiability anchor. HM-REQ-0060 requires every hypothesis to have at least one of: (a) a mechanical anchor (numeric outcome computable from artifacts; this is the implicit default for any spec with metrics), (b) an oracle reference (already covered by the `oracle` field), or (c) a public_benchmark reference declared here. Pure validator-consensus settlement is rejected at scoring time."
    }
  },

  "$defs": {
    "author": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "hotkey"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "hotkey": { "type": ["string", "null"] }
      }
    },

    "variable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "values"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "values": {
          "type": "array",
          "minItems": 1
        }
      }
    },

    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "units", "target_direction"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "units": { "type": "string", "minLength": 1 },
        "target_direction": {
          "type": "string",
          "enum": ["minimize", "maximize"]
        }
      }
    },

    "baseline": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },

    "protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dataset",
        "dataset_revision",
        "model_family",
        "model_config_ref",
        "seeds",
        "max_steps",
        "hardware_profile",
        "code_ref",
        "entrypoint"
      ],
      "properties": {
        "dataset": { "type": "string", "minLength": 1 },
        "dataset_revision": { "type": "string", "minLength": 1 },
        "model_family": { "type": "string", "minLength": 1 },
        "model_config_ref": { "type": "string", "minLength": 1 },
        "seeds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "integer", "minimum": 0 },
          "uniqueItems": true
        },
        "max_steps": { "type": "integer", "minimum": 1 },
        "hardware_profile": {
          "type": "string",
          "enum": [
            "cpu-small",
            "cpu-large",
            "single-gpu-24gb",
            "single-gpu-80gb",
            "multi-gpu-4x80gb"
          ]
        },
        "code_ref": { "type": "string", "minLength": 1 },
        "entrypoint": { "type": "string", "minLength": 1 }
      }
    },

    "criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric",
        "operator",
        "vs_baseline",
        "threshold_ratio",
        "statistical_test",
        "p_max"
      ],
      "properties": {
        "metric": { "type": "string", "minLength": 1 },
        "operator": {
          "type": "string",
          "enum": ["lt", "lte", "gt", "gte", "eq"]
        },
        "vs_baseline": { "type": "string", "minLength": 1 },
        "threshold_ratio": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "statistical_test": {
          "type": "string",
          "enum": ["welch_t", "bootstrap", "mann_whitney"]
        },
        "p_max": {
          "type": "number",
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 1
        },
        "seeds_required": { "type": "integer", "minimum": 1 }
      }
    },

    "oracle": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["subnet", "task_ref", "tolerance"],
          "properties": {
            "subnet": { "type": ["integer", "null"], "minimum": 0 },
            "task_ref": { "type": ["string", "null"] },
            "tolerance": { "type": ["number", "null"] }
          }
        }
      ]
    },

    "analysis_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pre_processing",
        "exclusion_criteria",
        "multiple_comparisons",
        "missing_seed_policy"
      ],
      "properties": {
        "pre_processing": {
          "type": "string",
          "minLength": 1,
          "description": "Free-text description of every pre-processing step applied to artifacts before metrics are computed. 'none' is acceptable; silence is not."
        },
        "exclusion_criteria": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Rules under which a seed or run is excluded from the analysis. Empty array means no exclusion is permitted; absent runs fail per `missing_seed_policy`."
        },
        "multiple_comparisons": {
          "type": "string",
          "enum": ["none", "bonferroni", "holm", "fdr_bh", "fdr_by"],
          "description": "Correction applied when more than one statistical test backs the success or falsification criteria. 'none' is admissible only when exactly one test is declared."
        },
        "missing_seed_policy": {
          "type": "string",
          "enum": ["fail", "exclude", "impute_median"],
          "description": "Policy for handling a seed whose metrics are absent in the manifest. 'fail' rejects the submission; 'exclude' drops the seed (still subject to `seeds_required`); 'impute_median' substitutes the median across present seeds."
        }
      }
    },

    "external_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["mechanical", "oracle", "public_benchmark"]
        },
        "subnet": { "type": "integer", "minimum": 0 },
        "task_ref": { "type": "string", "minLength": 1 },
        "tolerance": { "type": "number" },
        "url": {
          "type": "string",
          "pattern": "^https://"
        },
        "content_hash": {
          "type": "string",
          "pattern": "^(sha256:[0-9a-f]{64}|bafy[A-Za-z0-9]+|Qm[1-9A-HJ-NP-Za-km-z]{44})$"
        },
        "metric": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "oracle" } } },
          "then": { "required": ["type", "subnet", "task_ref", "tolerance"] }
        },
        {
          "if": { "properties": { "type": { "const": "public_benchmark" } } },
          "then": { "required": ["type", "url", "content_hash", "metric"] }
        }
      ]
    }
  }
}
